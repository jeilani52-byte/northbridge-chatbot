# ─────────────────────────────────────────────────────────────────
# Northbridge Digital Chatbot — Environment Variables
# Copy this file to .env and fill in your values
# ─────────────────────────────────────────────────────────────────

# Your OpenAI API key — get one at https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-openai-key-here

# Password to access the admin live-agent dashboard
# Change this to something strong!
ADMIN_PASSWORD=northbridge2025

# Port to run the server on (Railway/Render will set this automatically)
PORT=3000

# ── Email Notifications (Gmail SMTP) ─────────────────────────────────────────
# Your Gmail address used to SEND the alert emails
GMAIL_USER=you@gmail.com

# Gmail App Password (NOT your regular password)
# Create one at: myaccount.google.com/apppasswords
# Requires 2-Step Verification to be enabled on your Google account
GMAIL_APP_PASS=xxxx-xxxx-xxxx-xxxx

# Where to RECEIVE the alert emails (can be any email address)
NOTIFY_EMAIL=you@gmail.com
