# ─────────────────────────────────────────────────────────────────
# Northbridge Digital Chatbot — Environment Variables
# Copy this file to .env and fill in your values
# ─────────────────────────────────────────────────────────────────

# Your OpenAI API key — get one at https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-openai-key-here

# Password to access the admin live-agent dashboard
# Change this to something strong!
ADMIN_PASSWORD=northbridge2025

# Port to run the server on (Railway/Render will set this automatically)
PORT=3000

# ── Email Notifications (Outlook/Hotmail SMTP) ────────────────────────────────
# Your Microsoft email address (Outlook, Hotmail, Live, etc.)
OUTLOOK_USER=you@hotmail.com

# Your Microsoft account password OR an App Password if you have 2FA enabled.
# To create an App Password: account.microsoft.com → Security → App passwords
OUTLOOK_PASS=your-password-or-app-password

# Where to send the alert emails (defaults to OUTLOOK_USER if not set)
NOTIFY_EMAIL=you@hotmail.com
